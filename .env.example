# =================================================================
# 1. 项目基础配置 (General Project Configuration)
# =================================================================
PROJECT_NAME="Silver Pilot"
ENV="development"

# =================================================================
# 2. 数据库配置 (Database Configuration)
# =================================================================

# --- Neo4j (图数据库) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Milvus (向量数据库) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=medical_knowledge_base
MILVUS_KB_COLLECTION=medical_knowledge_base
MILVUS_QA_COLLECTION=medical_qa_lite
MILVUS_BATCH_SIZE=64
MILVUS_CONTENT_MAX_BYTES=16384
MILVUS_CONTENT_MAX_CHARS=5000

# --- Redis (会话管理 + 用户画像) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SESSION_TTL_SECONDS=2592000
USER_PROFILE_TTL_SECONDS=2592000

# =================================================================
# 3. 外部服务与 API Keys (External Services & APIs)
# =================================================================

# --- MinerU ---
MINERU_TOKEN=

# --- DashScope / Qwen ---
# OPENAI_API_KEY=sk-xxxx
DASHSCOPE_API_KEY=
QWEN_REGION=cn
# 备选配置:
# DASHSCOPE_API_KEY=sk-xxxx
# QWEN_REGION="sg"

# =================================================================
# 4. 向量与重排序模型配置 (Embedding & Reranking)
# =================================================================

# --- Embedding ---
# 可选值: "local" | "qwen"
EMBEDDER_MODE=local
EMBEDDER_LOCAL_MODEL=BAAI/bge-m3
EMBEDDER_CLOUD_MODEL=text-embedding-v3

# --- Reranking ---
RERANK_MODE=local
RERANK_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CLOUD_MODEL=qwen3-rerank
RERANK_TOP_K=8

# --- Entity Linking (实体链接) ---
ENTITY_LINK_MODEL=paraphrase-multilingual-MiniLM-L12-v2
ENTITY_LINK_THRESHOLD=0.85

# =================================================================
# 5. 各流程使用的模型选择 (Task-Specific LLM Models)
# =================================================================

# --- RAG ---
QUERY_PROCESS_MODEL=qwen3.5-flash
COMMUNITY_BUILDER_MODEL=qwen3.5-flash
PATH_REASONER_MODEL=qwen-flash
CONTEXT_BUILDER_MODEL=qwen-flash

# --- Agent ---
SUPERVISOR_MODEL=qwen3.5-flash
CHAT_AGENT_MODEL=qwen3.5-flash
DEVICE_AGENT_MODEL=qwen-flash
EMERGENCY_AGENT_MODEL=qwen3.5-flash
MEDICAL_AGENT_FAITHFULNESS_MODEL=qwen-flash
MEDICAL_AGENT_GENERATION_MODEL=qwen3.5-plus
MEMORY_SUMMARIZE_MODEL=qwen-flash
MEMORY_WRITER_AGENT=qwen-flash
RESPONSE_SYNTHESIZER_MODEL=qwen3.5-flash

# --- Perception ---
PERCEPTION_AUDIO_ASR_MODEL=qwen3-asr-flash
VISION_UNDERSTANDING_MODEL=qwen3.5-flash

# =================================================================
# 6. 检索与检索增强 (Retriever & Strategy)
# =================================================================

# --- 功能开关 ---
VECTOR_KB_ENABLED=True
VECTOR_QA_ENABLED=True
GRAPH_RETRIEVER_ENABLE_COMMUNITY=True
GRAPH_RETRIEVER_ENABLE_REASONING=True

# --- 检索参数 ---
VECTOR_RETRIEVAL_TOP_K=5
GRAPH_RETRIEVER_MAX_RESULTS_PER_ENTITY=10

# --- 社区分析参数 (Community Analysis) ---
MAX_COMMUNITIES=5
MIN_COMMUNITY_SIZE=3
MAX_COMMUNITY_SIZE_FOR_SUMMARY=200
COMMUNITY_ENTITY_RETRIEVAL_WEIGHT=1.0
COMMUNITY_QUERY_RETRIEVAL_WEIGHT=0.5

# --- 路径推理强度 (Path Reasoning) ---
PATH_REASONER_MAX_HOPS=3
PATH_REASONER_MAX_PATHS=5

# --- 上下文构建模式 (Context Building) ---
CONTEXT_BUILDER_MODE=direct
MAX_CONTEXT_CHARS=3000

# =================================================================
# 7. Agent 运行参数 (Agent Runtime Parameters)
# =================================================================

# --- 调度与重试 ---
MAX_SUPERVISOR_LOOPS=5
MAX_RETRY_PER_AGENT=2
HALLUCINATION_THRESHOLD=0.3

# --- 记忆压缩 ---
COMPRESS_THRESHOLD=14
KEEP_RECENT_TURNS=6
SUMMARY_MAX_TOKENS=400

# --- Chat Agent ---
CHAT_AGENT_TEMPERATURE=0.7
CHAT_AGENT_MAX_TOKENS=300
CHAT_AGENT_SUMMARY_TURNS=6

# --- Device Agent ---
DEVICE_AGENT_TEMPERATURE=0.0

# --- Memory Writer ---
MEMORY_WRITER_EXTRACT_INTERVAL=6

# --- Medical Agent ---
MEDICAL_AGENT_SUMMARY_TURNS=6

# --- Response Synthesizer ---
RESPONSE_SYNTHESIZER_TEMPERATURE=0.3
RESPONSE_SYNTHESIZER_MAX_TOKENS=800
